PORT=5000
NODE_ENV=development

# SQL Server Configuration (Option 1)
DATABASE_URL="sqlserver://localhost:1433;database=document_management;user=YOUR_USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# MySQL Configuration Example (Option 2)
# DATABASE_URL="mysql://root:password@localhost:3306/document_management"

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

STORAGE_TYPE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

BCRYPT_SALT_ROUNDS=10

# VNPAY Configuration
VNP_TMNCODE=your_vnp_tmn_code
VNP_HASHSECRET=your_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=http://localhost:5000/api/vnpay/vnpay_return

# Frontend payment result pages (BE redirects here after VNPay return)
PAYMENT_RESULT_BASE_URL=http://localhost:5173/payment-result
PAYMENT_SUCCESS_URL=http://localhost:5173/payment-result?status=success
PAYMENT_FAILED_URL=http://localhost:5173/payment-result?status=failed
