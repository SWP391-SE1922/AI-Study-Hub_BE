{
  "name": "backend",
  "version": "1.0.0",
  "description": "Student Document Management System Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "setup": "npm run db:fix",
    "seed": "node prisma/seed.js",
    "migrate": "npx prisma migrate dev",
    "studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:admin": "node prisma/create-admin.js",
    "db:fix": "npx prisma generate && npx prisma db push && node prisma/create-admin.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@payos/node": "^2.0.5",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.5.3",
    "mammoth": "^1.12.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-pptx-parser": "^1.0.1",
    "nodemailer": "^8.0.11",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "qs": "^6.15.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "vectordb": "^0.21.2",
    "vnpay": "^2.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0"
  }
}
